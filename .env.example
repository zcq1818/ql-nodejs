# 面板访问密码（必填，部署时在 Vercel 环境变量里设置；本地开发也会读取）
PANEL_PASSWORD=change_me_strong_password

# Vercel KV（在 Vercel 控制台创建 KV 存储后会自动注入下面两个变量，
# 本地开发若不填则自动退化为内存存储，仅本次运行有效）
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# 全局通知（可选）
# SERVER_KEY=     微信 Server 酱 SCK（sctapi.ftqq.com 获取）
# SMTP_HOST=
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
# NOTIFY_TO=      接收通知的邮箱，多个用逗号分隔
